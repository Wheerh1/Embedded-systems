  volumeLevel = map(micValue, 0, 4095, 0, 100); //further stabilises values
  Serial.print(micValue);
  Serial.print(" mapped: ");
  Serial.println(volumeLevel);

  if(volumeLevel <= 33){
    tft.writeRect(0, 0, 320, 240, XEye_black); //tft.writeRect(x_pos, y_pos, bmp_width, bmp_height, testBitmap);
  } else if (volumeLevel >= 66){
    tft.writeRect(0, 0, 320, 240, heart_eye); //tft.writeRect(x_pos, y_pos, bmp_width, bmp_height, testBitmap);
  } else if (volumeLevel > 33 && volumeLevel < 66){
    tft.writeRect(0, 0, 320, 240, speakingEye_Left); //tft.writeRect(x_pos, y_pos, bmp_width, bmp_height, testBitmap);
  }

  delay(100);
}
