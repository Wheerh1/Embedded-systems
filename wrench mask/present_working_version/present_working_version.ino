// Array of all bitmaps for convenience. (Total bytes used to store images in PROGMEM = 2080)
const int eye_bitmapallArray_LEN = 2;
const unsigned char* eye_bitmapallArray[2] = {
eye_bitmapeye__,
eye_bitmapeye_x
};

int micVol;
int countdown = 0;

void setup() {
  pinMode(A0, INPUT_PULLUP); //internal pullup resistor enabled in order to clean up signal
  u8g2.begin(); //required to start u8g2 
  Serial.begin(9600);
}

void loop() {
  u8g2.clearBuffer();
  micVol = analogRead(A0);
  Serial.print(micVol);
  
  if (micVol >=200){
    countdown = 20; //number of loops eye is changed for
    Serial.print(" -resetting count");
  }
  
  if(countdown > 0){
    u8g2.drawXBMP(0, 0, 128, 64, eye_bitmapeye__ ); //.drawBitmapP command is depreciated
    countdown -= 1;
    Serial.print(" -count -1");
  }
  else{
    // draw the bitmap (x, y, width, height, bitmap)
    u8g2.drawXBMP(0, 0, 128, 64, eye_bitmapeye_x); 
  }
  Serial.println();
  
  u8g2.sendBuffer();           
  delay(100);
}
